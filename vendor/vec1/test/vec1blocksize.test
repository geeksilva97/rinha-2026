source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1blocksize
vec1_load db

do_execsql_test 1.0 {
  CREATE VIRTUAL TABLE v1 USING vec1;
}

do_catchsql_test 1.1 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize', 64);
} {1 {'blocksize' requires an integer value between 1024 and 16777216}}

do_catchsql_test 1.2 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize', 1023);
} {1 {'blocksize' requires an integer value between 1024 and 16777216}}

do_catchsql_test 1.3 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize', 16777217);
} {1 {'blocksize' requires an integer value between 1024 and 16777216}}

do_execsql_test 1.4 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize', 1024);
  INSERT INTO v1(cmd, arg) VALUES('blocksize', 16777216);
} {}

do_catchsql_test 2.1 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize-min', 64);
} {1 {'blocksize-min' requires an integer value between 1024 and 16777216}}

do_catchsql_test 2.2 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize-min', 1023);
} {1 {'blocksize-min' requires an integer value between 1024 and 16777216}}

do_catchsql_test 2.3 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize-min', 16777217);
} {1 {'blocksize-min' requires an integer value between 1024 and 16777216}}

do_execsql_test 2.4 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize-min', 1024);
  INSERT INTO v1(cmd, arg) VALUES('blocksize-min', 16777216);
} {}

do_catchsql_test 3.0 {
  INSERT INTO v1(cmd, arg) VALUES('not-blocksize', 1024);
} {1 {vec1: unknown command: not-blocksize}}

do_catchsql_test 3.1 {
  INSERT INTO v1(cmd, arg) VALUES('blocksize', 'not integer');
} {1 {'blocksize' requires an integer value between 1024 and 16777216}}

finish_test

