source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1limit
vec1_load db


do_execsql_test 1.0 { 
  CREATE VIRTUAL TABLE v1 USING vec1(v, a, b);
  INSERT INTO v1 VALUES(random_vector(16), 555, 111);
  DELETE FROM v1;
}

do_catchsql_test 1.1 {
  SELECT * FROM v1(:q) 
} {1 {vec1: unexpected vector blob size 0 bytes, expected 64}}

set q [db one {SELECT random_vector(16)}]
foreach {tn sql} {
  1 { SELECT * FROM v1($q) }
  2 { SELECT * FROM v1($q) ORDER BY vec1_l2_distance(v, $q) LIMIT 10 }
  3 { SELECT * FROM v1($q) WHERE a!=b LIMIT 10 }
  4 { SELECT * FROM v1($q) LIMIT -1 }
  5 { SELECT * FROM v1($q) WHERE a LIKE 'p%' LIMIT 10 }
} {
  do_catchsql_test 1.2.$tn $sql [list \
    1 {vec1: no K value or visible LIMIT clause}
  ]
}

foreach {tn sql} {
  1 { SELECT * FROM v1($q) LIMIT 10 }
  2 { SELECT * FROM v1($q) WHERE a=555 LIMIT 10 }
} {
  do_execsql_test 1.3.$tn $sql {}
}





finish_test

