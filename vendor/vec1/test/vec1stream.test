source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1stream
vec1_load db


do_execsql_test 1.0 {
  CREATE VIRTUAL TABLE v1 USING vec1(v);
  WITH s(i) AS (
    SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<1000
  )
  INSERT INTO v1(rowid, v) SELECT i, random_vector(16) FROM s;

  INSERT INTO v1(cmd, arg) 
  SELECT 'rebuild', vec1_train(v, '{nbucket:32, codesize:0}') FROM v1;
}

do_test 1.1 {
  llength [
    db eval {
      SELECT rowid FROM v1(random_vector(16), '{K:10, nprobe: 1, streaming:0}')
    }
  ]
} {10}

do_test 1.2 {
  llength [
    db eval {
      SELECT rowid FROM v1(
          random_vector(16), '{K:1000, nprobe: 32, streaming:0}'
      )
    }
  ]
} {1000}

do_test 1.3 {
  llength [
    db eval {
      SELECT rowid FROM v1(random_vector(16), '{K:10, nprobe: 1, streaming:1}')
    }
  ]
} {1000}

proc repeat {str n} {
  string repeat $str $n
}
db func repeat repeat

do_execsql_test 2.0 {
  CREATE VIRTUAL TABLE v2 USING vec1(v, m);
  WITH s(i) AS (
    SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<1000
  )
  INSERT INTO v2(rowid, v, m) SELECT i, random_vector(16), repeat(i,200) FROM s;

  INSERT INTO v2(cmd, arg) 
  SELECT 'rebuild', vec1_train(v, '{nbucket:32, codesize:0}') FROM v1;
}

breakpoint
do_test 2.1 {
  llength [
    db eval {
      SELECT rowid 
      FROM v2(random_vector(16), '{K:10, nprobe: 1, streaming:1}')
      WHERE m=repeat(555,200)
    }
  ]
} {1}

finish_test

