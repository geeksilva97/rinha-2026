source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1config
vec1_load db

do_execsql_test 1.0 { SELECT vec1_config('nthread'); } {1}
do_execsql_test 1.1 { SELECT vec1_config('nprobe'); } {0.05}

do_catchsql_test 1.2 { 
  SELECT vec1_config('nosuch'); 
} {1 {vec1: no such parameter: nosuch}}

do_catchsql_test 1.3.1 { 
  SELECT vec1_config('nthread', 0); 
} {1 {vec1: nthread requires an integer value between 1 and 128}}
do_catchsql_test 1.3.2 { 
  SELECT vec1_config('nthread', 129); 
} {1 {vec1: nthread requires an integer value between 1 and 128}}
do_test 1.3.3 { 
  catch { execsql { SELECT vec1_config('nthread', 128) } }
} {0}
do_catchsql_test 1.3.4 { 
  SELECT vec1_config('nthread', 1); 
} {0 1}

do_catchsql_test 1.4.1 { 
  SELECT vec1_config('nprobe', -1); 
} {1 {vec1: nprobe requires a value larger than 0.0}}
do_catchsql_test 1.4.2 { 
  SELECT vec1_config('nprobe', 0.0); 
} {1 {vec1: nprobe requires a value larger than 0.0}}
do_catchsql_test 1.4.3 { 
  SELECT vec1_config('nprobe', 4.0); 
} {0 4.0}

do_catchsql_test 1.5.1 { 
  SELECT vec1_config('nthread', 'notaninteger'); 
} {1 {vec1: nthread requires an integer value between 1 and 128}}

finish_test

