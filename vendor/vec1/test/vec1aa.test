#-------------------------------------------------------------------------

reset_db
vec1_load db

do_execsql_test 3.0 {
  CREATE VIRTUAL TABLE v1 USING vec1;
  INSERT INTO v1(cmd, vector) VALUES('rebuild', '{index:"flat"}');

  BEGIN;
    INSERT INTO v1(rowid, vector) VALUES(1, random_vector(8));
    INSERT INTO v1(rowid, vector) VALUES(2, random_vector(8));
    INSERT INTO v1(rowid, vector) VALUES(3, random_vector(8));
  COMMIT;

  PRAGMA integrity_check;
} {ok}

do_execsql_test 3.1 {
  DELETE FROM v1 WHERE rowid=2;
  PRAGMA integrity_check;
} {ok}

do_execsql_test 3.2 {
  SELECT rowid FROM v1
} {1 3}

do_execsql_test 3.3 {
  SELECT rowid FROM v1( random_vector(8), 5 ) ORDER BY 1;
} {1 3}

do_execsql_test 3.4 {
  WITH s(i) AS ( SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<100 )
  INSERT INTO v1 SELECT random_vector(8);
  WITH s(i) AS ( SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<100 )
  INSERT INTO v1 SELECT random_vector(8);
  WITH s(i) AS ( SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<100 )
  INSERT INTO v1 SELECT random_vector(8);
}

do_execsql_test 3.5 {
  DELETE FROM v1 WHERE rowid IN (5, 105, 205, 77, 98, 222);
  PRAGMA integrity_check;
} {ok}

#-------------------------------------------------------------------------

reset_db
vec1_load db
do_execsql_test 4.0 {
  CREATE VIRTUAL TABLE v1 USING vec1;
  INSERT INTO v1(cmd, vector) VALUES('rebuild', '{index:"flat"}');
}

do_execsql_test 4.1 {
  BEGIN;
    INSERT INTO v1 (rowid, vector) VALUES( 0x1_0000_0001, random_vector(8) );
    INSERT INTO v1 (rowid, vector) VALUES( 0x1_0000_0002, random_vector(8) );
    INSERT INTO v1 (rowid, vector) VALUES( 0x1_0000_0003, random_vector(8) );
    INSERT INTO v1 (rowid, vector) VALUES( 0x1_0000_0004, random_vector(8) );
  COMMIT;
}

do_execsql_test 4.2 {
  PRAGMA integrity_check;
} {ok}

do_execsql_test 4.3 {
  DELETE FROM v1 WHERE rowid = 0x1_0000_0003;
} {}

do_execsql_test 4.4 {
  PRAGMA integrity_check;
} {ok}

#-------------------------------------------------------------------------
reset_db
vec1_load db
do_execsql_test 4.0 {
  CREATE VIRTUAL TABLE v1 USING vec1;
  INSERT INTO v1(cmd, vector) VALUES('rebuild', '{index:"flat"}');
}

do_execsql_test 4.1 {
  INSERT INTO v1 VALUES( random_vector( 16 ) );
}

do_execsql_test 4.2 {
  INSERT INTO v1 VALUES( random_vector( 16 ) );
  SELECT count(*) FROM v1_idx;
} {1}

do_execsql_test 4.3 {
  PRAGMA integrity_check
} {ok}

#-------------------------------------------------------------------------
#
reset_db
vec1_load db

do_execsql_test 5.0 {
  CREATE VIRTUAL TABLE v1 USING vec1;
  INSERT INTO v1(cmd, vector) VALUES('rebuild', '{index:"flat"}');
}

do_execsql_test 5.1 {
  INSERT INTO v1 VALUES( random_vector( 16 ) );
  INSERT INTO v1 VALUES( random_vector( 16 ) );
  INSERT INTO v1 VALUES( random_vector( 16 ) );
}

do_execsql_test 5.2 {
  BEGIN;
    INSERT INTO v1(rowid, vector) VALUES(11, random_vector( 16 ) );
    INSERT INTO v1(rowid, vector) VALUES(12, random_vector( 16 ) );
    DELETE FROM v1 WHERE rowid=11;
  COMMIT;
} {}

do_execsql_test 5.3 {
  PRAGMA integrity_check
} {ok}

#-------------------------------------------------------------------------
#
reset_db
vec1_load db

do_execsql_test 6.0 {
  CREATE VIRTUAL TABLE v1 USING vec1(x);
  INSERT INTO v1 VALUES( random_vector(22) );
}
do_catchsql_test 6.1 {
  INSERT INTO v1 VALUES( random_vector(23) );
} {1 {vec1: unexpected vector blob size 92 bytes, expected 88}}

#-------------------------------------------------------------------------
#
reset_db
vec1_load db

do_execsql_test 6.0 {
  CREATE VIRTUAL TABLE v1 USING vec1(x);
}
do_catchsql_test 6.1 {
  INSERT INTO v1(cmd, arg) VALUES('rebuild', '{distance:"l2"}');
} {1 {vec1: required parameter missing: index}}

do_execsql_test 6.2 {
 INSERT INTO v1 VALUES(random_vector(16));
 INSERT INTO v1 VALUES(random_vector(16));
 INSERT INTO v1 VALUES(random_vector(16));
 INSERT INTO v1 VALUES(random_vector(16));
 INSERT INTO v1 VALUES(random_vector(16));

 UPDATE v1_base SET vector = random_vector(15) WHERE id=4;
}

do_catchsql_test 6.1 {
  INSERT INTO v1(cmd, arg) VALUES('rebuild', '{index:"flat",distance:"l2"}');
} {1 {vec1: unexpected vector size in v1_base: 60}}


finish_test

