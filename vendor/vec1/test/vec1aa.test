source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1aa
vec1_load db

do_execsql_test 1.0 {
  CREATE VIRTUAL TABLE v1 USING vec1;
}

do_execsql_test 1.0.1 { SELECT vec1_config('nthread'); } {1}
do_execsql_test 1.0.2 { SELECT vec1_config('nprobe'); } {0.05}

do_execsql_test 1.1 {
  INSERT INTO v1(cmd, vector) VALUES('rebuild', '{index:"flat"}');
  INSERT INTO v1(rowid, vector) VALUES(
     1, vec1_from_json('[1,2,3,4,5,6,7,8]')
  );
}

do_execsql_test 1.2 { PRAGMA integrity_check } {ok}

do_execsql_test 1.3 {
  DELETE FROM v1_base;
  PRAGMA integrity_check;
} {{v1: %_idx row 1 missing from %_base}}

do_execsql_test 1.4 {
  DROP TABLE v1;
}

do_execsql_test 1.5 {
  CREATE VIRTUAL TABLE v1 USING vec1;
  INSERT INTO v1(cmd, vector) VALUES('rebuild', '{index:"flat"}');
  INSERT INTO v1(rowid, vector) VALUES(1, vec1_from_json('[1,2,3,4]'));
  BEGIN;
    SAVEPOINT aaa;
      INSERT INTO v1(rowid, vector) VALUES(2, vec1_from_json('[1,2,3,4]'));
    ROLLBACK TO aaa;
  COMMIT;

  PRAGMA integrity_check;
} {ok}

do_execsql_test 1.6 {
  BEGIN;
    INSERT INTO v1(rowid, vector) VALUES(3, vec1_from_json('[1,2,3,4]'));
  ROLLBACK;
  INSERT INTO v1(rowid, vector) VALUES(4, vec1_from_json('[1,2,3,4]'));
  PRAGMA integrity_check;
} {ok}

