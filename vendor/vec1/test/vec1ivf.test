source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1flat
vec1_load db


do_execsql_test 1.0 {
  CREATE VIRTUAL TABLE v1 USING vec1(v);
  WITH s(i) AS (
    SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<1000
  )
  INSERT INTO v1(v) SELECT random_vector(32) FROM s;
  INSERT INTO v1(cmd, arg) VALUES('rebuild', (
    SELECT vec1_train(v, '{nbucket:24, codesize:0}') FROM v1
  ));
}

db close
sqlite3 db test.db
vec1_load db

do_execsql_test 1.1 {
  SELECT length(v) FROM v1 LIMIT 1
} {128}


finish_test

