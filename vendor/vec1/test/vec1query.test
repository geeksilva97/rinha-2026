source [file join [file dirname [info script]] vec1_common.tcl]
set testprefix vec1query
vec1_load db

do_execsql_test 1.0 {
  CREATE VIRTUAL TABLE v1 USING vec1(v);
}

do_execsql_test 1.1 {
  WITH s(i) AS (
    SELECT 1 UNION ALL SELECT i+1 FROM s WHERE i<1000
  )
  INSERT INTO v1 SELECT random_vector(24) FROM s;
}

do_execsql_test 1.2 {
 INSERT INTO v1(cmd, arg) VALUES('rebuild', (
   SELECT vec1_train(v, '{codesize:8, nbucket:16, distance:"cos"}') FROM v1
 ));
}

set v [db one {SELECT random_vector(24)}]
set p "{K:50,nprobe:8}"
do_execsql_test 1.3 {
  SELECT (SELECT rowid FROM v1($v, $p) ORDER BY vec1_l2_distance(v, $v))
       ==(SELECT rowid FROM v1 ORDER BY vec1_l2_distance(v, $v))
} {1}

set v [db one {SELECT random_vector(24)}]
set p "{K:50,nprobe:0.5}"
do_execsql_test 1.4 {
  SELECT (SELECT rowid FROM v1($v, $p) ORDER BY vec1_l2_distance(v, $v))
       ==(SELECT rowid FROM v1 ORDER BY vec1_l2_distance(v, $v))
} {1}

set v [db one {SELECT random_vector(24)}]
set p "{K:50,nprobe:null}"
do_catchsql_test 1.5 {
  SELECT (SELECT rowid FROM v1($v, $p) ORDER BY vec1_l2_distance(v, $v))
       ==(SELECT rowid FROM v1 ORDER BY vec1_l2_distance(v, $v))
} {1 {vec1: null value in json object}}

do_catchsql_test 1.6 {
  SELECT rowid FROM v1($v, -10)
} {1 {vec1: K must be greater than 0 (have -10)}}

set v [db one {SELECT random_vector(24)}]
set p "{K:50,nprobe:8,nprobe_slack:0.8}"
do_execsql_test 1.7 {
  SELECT (SELECT rowid FROM v1($v, $p) ORDER BY vec1_l2_distance(v, $v))
       ==(SELECT rowid FROM v1 ORDER BY vec1_l2_distance(v, $v))
} {1}

set v [db one {SELECT random_vector(24)}]
set p "{K:50,nprobe:8,nprobe_slack:0.2}"
do_execsql_test 1.8 {
  SELECT (SELECT rowid FROM v1($v, $p) ORDER BY vec1_l2_distance(v, $v))
       ==(SELECT rowid FROM v1 ORDER BY vec1_l2_distance(v, $v))
} {1}

finish_test

