package require Expect
 
# Tcl procedure for a "Human-ish" Bell Curve delay
# mean: the average delay in milliseconds
# jitter: how much it can swing (higher = more erratic)
#
proc get_gaussian_delay {mean jitter} {
  # Summing 3 randoms creates a natural bell curve (clumping at the mean)
  set r1 [expr {rand()}]
  set r2 [expr {rand()}]
  set r3 [expr {rand()}]

  # Calculate the offset: (sum - 1.5) centers the range at 0
  set offset [expr {($r1 + $r2 + $r3 - 1.5) * $jitter}]

  # Round to an integer for 'after'
  return [expr {round($mean + $offset)}]
}

proc mysend {string {bWait 0}} {
  foreach char [split $string ""] {
    exp_send -- $char
    # This forces the pty to process and display the character immediately
    expect -ex $char
    # Control speed manually
    after [get_gaussian_delay 60 50]
  }

  if {$bWait} {
    wait_for_click
  } else {
    after 1000
  }
  exp_send -- "\n"
}

button .b -command buttoncommand -text CONTINUE
pack .b -expand 1 -fill both
set ::buttonpress 0
proc buttoncommand {args} {
  incr ::buttonpress
}

proc wait_for_click {} {
  vwait ::buttonpress
}

proc sql {args} {
  if {[llength $args]>2} {
    error "usage: sql [switch] SQL"
  }
  set bWait 0
  set bClick 0
  if {[llength $args]==2} {
    switch -- [lindex $args 0] {
      -1 {
        set bClick 1
      }
      -2 {
        set bClick 1
        set bWait 1
      }
      default {
        error "bad option: [lindex $args 0]"
      }
    }
  }
  set cmd [lindex $args end]
  mysend $cmd $bWait
  expect "sqlite> "
  if {$bClick} wait_for_click
}

# Start sqlite3
spawn /home/dan/work/sqlite/cfgbld/sqlite3 sift1m.db

# Wait for the sqlite prompt
expect "sqlite> "

sql "SELECT count(vec) FROM v1;"
sql "DROP TABLE IF EXISTS v1;"
sql "SELECT vec1_config('nprobe', 16);"
sql {.shell clear}

wait_for_click
sql -1 "SELECT vec1_info();"
sql -1 {-- 1,000,000 128d vectors from http://corpus-texmex.irisa.fr/}
sql -1 {SELECT count(*), min( length(vec) ), max( length(vec) ) FROM base;}
sql -1 {.param set :q "(SELECT vec FROM test WHERE rowid=1000)"}
sql -1 ".timer on"
sql -2 {SELECT rowid FROM base ORDER BY vec1_l2_distance(:q, vec) LIMIT 10;}
sql -1 {SELECT group_concat(rowid) FROM (
    SELECT rowid FROM base ORDER BY vec1_l2_distance(:q, vec) LIMIT 10
);}
sql -1 {.shell clear}
sql -1 {CREATE VIRTUAL TABLE v1 USING vec1(vec);}
sql -1 {INSERT INTO v1(rowid, vec) SELECT rowid, vec FROM base;}
sql -1 {SELECT group_concat(rowid) FROM (
    SELECT rowid FROM v1(:q, 10)
);}
sql -1 {SELECT vec1_config('nthread', 16);}
sql -2 {INSERT INTO v1(cmd, arg) VALUES('rebuild',
    (SELECT vec1_train(vec, '{nbucket:1024, codesize: 16}') FROM learn)
);}
sql -1 {SELECT group_concat(rowid) FROM (
    SELECT rowid FROM v1(:q, 10)
);}
sql -2 {SELECT group_concat(rowid) FROM (
    SELECT rowid FROM v1(:q, 100) ORDER BY vec1_l2_distance(:q, vec) LIMIT 10
);}

after 1000
exit




