# Git / docs / dev junk
.git
.gitignore
.ruby-lsp
.bundle
README.md
CLAUDE.md
notes/
test.sh
run.sh

# Source dataset (~50MB, huge; offline-only)
resources/references.json.gz
resources/example-payloads.json
resources/example-references.json

# Built artifacts (will be rebuilt for the target platform)
vendor/vec1/vec1.dylib
vendor/vec1/*.so
vendor/vec1/*.o
vendor/vec1/*.a

# Ruby C++ extension artifacts built locally (Mach-O, won't link on Linux)
ext/**/Makefile
ext/**/*.o
ext/**/*.so
ext/**/*.bundle
ext/**/*.bundle.dSYM
ext/**/mkmf.log

# native/ standalone build outputs + dev quirks
native/bin/
native/_compat/
native/references.json
native/ivf.bin

# Upstream extras not used at runtime
vendor/vec1/doc
vendor/vec1/test
vendor/vec1/tool
vendor/vec1/Makefile
vendor/vec1/Makefile.msc
vendor/vec1/vec1_faiss.cpp

# Local fraud.db journals (only the prebuilt fraud.db file is needed)
fraud.db-journal
fraud.db-wal
fraud.db-shm

# Bin scripts only needed offline (ingest/train run on the host)
bin/
